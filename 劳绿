-- 可自由开启关闭的跳跃功能
local JumpEnabled = false
local JumpPowerValue = 50

Tabs.GeneralTab:Toggle({
    Title = "开启跳跃增强",
    Value = false,
    Callback = function(state) 
        JumpEnabled = state
        if state then
            WindUI:Notify({
                Title = "劳绿脚本",
                Content = "已开启跳跃增强",
                Icon = "check",
                Duration = 2
            })
            
            local jumpLoop
            jumpLoop = game:GetService("RunService").Heartbeat:Connect(function()
                if JumpEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                    LocalPlayer.Character.Humanoid.JumpPower = JumpPowerValue
                elseif not JumpEnabled and jumpLoop then
                    jumpLoop:Disconnect()
                    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                        LocalPlayer.Character.Humanoid.JumpPower = 50
                    end
                end
            end)
        else
            WindUI:Notify({
                Title = "劳绿脚本",
                Content = "已关闭跳跃增强",
                Icon = "x",
                Duration = 2
            })
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid.JumpPower = 50
            end
        end
    end
})

